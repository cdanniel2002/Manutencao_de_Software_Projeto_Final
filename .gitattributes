# Normaliza quebras de linha: tudo em LF no repositório e na cópia de
# trabalho. Evita os avisos "LF will be replaced by CRLF" no Windows e
# garante que scripts shell funcionem dentro dos containers Docker.
* text=auto eol=lf

# Scripts shell PRECISAM de LF (CRLF quebra o shebang no Linux/Docker)
*.sh    text eol=lf
entrypoint.sh text eol=lf

# Arquivos específicos do Windows usam CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Tipos de texto comuns (deixados explícitos por clareza)
*.py    text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.svg   text eol=lf
Dockerfile text eol=lf

# Binários: o Git não deve mexer
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
