DEBUG=False
SECRET_KEY='secret_key'
# Em producao (Render) inclua o dominio do servico, ex.: meu-backend.onrender.com
ALLOWED_HOSTS='localhost, 127.0.0.1'
# Em producao inclua o dominio do front na Vercel, ex.: https://meu-front.vercel.app
CORS_ALLOWED_ORIGINS='http://example.com, https://sub.example.com, http://localhost:8080, http://127.0.0.1:9000'
CORS_ALLOW_ALL_ORIGINS=False
# Necessario para o admin/djoser em HTTPS. Ex.: https://meu-backend.onrender.com, https://meu-front.vercel.app
CSRF_TRUSTED_ORIGINS=''

BACKEND_URL='http://localhost:8000'

SERVER_NAME='localhost'

# --- Banco de dados ---------------------------------------------------------
# Opcao A (Render): basta definir DATABASE_URL com a "Internal Database URL"
# do Postgres do Render. Quando preenchida, ela tem prioridade sobre o resto.
DATABASE_URL=''
# DB_SSL_REQUIRE=True  # Render exige SSL (ja e o padrao quando ha DATABASE_URL)

# Opcao B (docker-compose local): USE_POSTGRESQL=True + variaveis DB_* abaixo.
USE_POSTGRESQL=False

# Database Configurations
DB_NAME='Database Name'
DB_USER='Database Username'
DB_PASSWORD='Database Password'
DB_HOST='Database Host'
DB_PORT='Database Port'

# Email Configurations
EMAIL_BACKEND='django.core.mail.backends.smtp.EmailBackend'
EMAIL_HOST='smtp.gmail.com'
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER='Your Email'
EMAIL_HOST_PASSWORD='Your Password'

# Djoser Configurations
DJOSER_EMAIL_FRONTEND_PROTOCOL='http',
DJOSER_EMAIL_FRONTEND_DOMAIN='localhost:5173'
DJOSER_EMAIL_FRONTEND_SITE_NAME='FinanSee'

# Imagem Docker no GHCR (usada pelo docker-compose para puxar do registry)
# IMAGE_OWNER = dono do repositorio no GitHub (em minusculas)
# IMAGE_TAG   = 'latest' ou 'sha-<commit>' para fixar uma versao especifica
IMAGE_OWNER='cdanniel2002'
IMAGE_TAG='latest'
